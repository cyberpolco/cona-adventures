// Use SQLite for local dev; swap provider to "postgresql" + update DATABASE_URL for production.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String
  createdAt    DateTime  @default(now())
  bookings     Booking[]
}

model Booking {
  id            String     @id @default(cuid())
  ref           String     @unique
  userId        String?
  user          User?      @relation(fields: [userId], references: [id])
  country       String
  adults        Int        @default(1)
  children      Int        @default(0)
  experiences   String     @default("[]") // JSON array stored as text
  accommodation String?
  payType       String     @default("full")
  priceTotal    Int
  priceCharged  Int
  status        String     @default("pending") // pending | paid | cancelled
  travelers     Traveler[]
  payments      Payment[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Traveler {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  firstName String
  lastName  String
  email     String?
  phone     String?
  passport  String? // file reference only — never store PII binary here
  dob       String?
  createdAt DateTime @default(now())
}

model Payment {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id])
  txRef         String   @unique
  transactionId String?
  amount        Float
  currency      String
  status        String   @default("pending") // pending | successful | failed
  gateway       String   @default("flutterwave")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GallerySubmission {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  caption   String?
  fileRef   String? // object storage reference; never store file binary here
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GuideRating {
  id        String   @id @default(cuid())
  guideId   String?
  rating    Int
  comment   String?
  traveler  String?
  createdAt DateTime @default(now())
}
